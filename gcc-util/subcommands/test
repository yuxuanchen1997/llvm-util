#!/bin/sh

set -e

usage() {
  cat <<EOF
Usage: $(basename "$0") <test-paths...>

Run GCC tests using dejagnu (runtest).

Arguments:
  test-paths  Paths to test files (e.g., gcc.dg/ifcvt-fabs-1.c)

Options:
  -h, --help  Show this help message

Examples:
  $(basename "$0") gcc.dg/ifcvt-fabs-1.c
  $(basename "$0") g++.dg/cpp0x/attr-trivial_abi1.C
EOF
}

if [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
  usage
  exit 0
fi

if [ -z "$1" ]; then
  >&2 echo "Error: Missing required argument: test-paths"
  >&2 echo
  usage >&2
  exit 1
fi

# Detect if tests are g++ or gcc based on file paths
TOOL="gcc"
for arg in "$@"; do
  case "$arg" in
    *g++.dg*|*g++.old-deja*)
      TOOL="g++"
      break
      ;;
  esac
done

if [ "$GCC_USE_CMAKE" = "1" ]; then
  cd "$GCC_BUILD_DIR/testsuite/$TOOL"
else
  cd "$GCC_BUILD_DIR/$TOOL"
fi

# Run each test individually to handle subdirectory tests correctly
for arg in "$@"; do
  arg="${arg#gcc/testsuite/}"
  file="$(basename "$arg")"
  dir="$(dirname "$arg")"
  # Get the dg/old-deja/etc part (first component after gcc./g++.)
  expname="$(echo "$dir" | sed -n 's/^[^.]*\.\([^/]*\).*/\1/p')"
  expname="${expname#gcc}"
  expname="${expname#g++}"
  # If no dot notation, use the first directory component
  if [ -z "$expname" ]; then
    expname="$(echo "$dir" | cut -d/ -f1)"
    expname="${expname#gcc-}"
    expname="${expname#g++-}"
  fi
  runtest --tool "$TOOL" ${expname}.exp=${file}
done
